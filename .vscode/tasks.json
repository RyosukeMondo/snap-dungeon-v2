{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Godot Project",
      "type": "shell",
      "command": "godot",
      "args": ["--path", "${workspaceFolder}", "--debug"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
